class HybridClusterManager:
    """Sistema que testa múltiplos algoritmos de clustering"""

    def __init__(self, config: ClusteringConfig = None, alt_config: AlternativeClusteringConfig = None):
        self.config = config or ClusteringConfig()
        self.alt_config = alt_config or AlternativeClusteringConfig()
        self.scaler = RobustScaler()
        self.best_method = None
        self.best_score = -1
        self.best_labels = None

    def prepare_features_optimized(self, df_technical: pd.DataFrame) -> pd.DataFrame:
        """Pré-processamento otimizado"""
        print("🔬 PREPARANDO FEATURES OTIMIZADAS...")

        features = self._aggregate_core_features(df_technical)

        if features.empty:
            return self._create_minimal_features(df_technical)

        # Remoção moderada de outliers
        features = self._remove_outliers_moderate(features)

        # Seleção robusta de features
        features = self._apply_robust_feature_selection(features)

        # Redução dimensional conservadora
        features = self._apply_conservative_dimensionality_reduction(features)

        return features

    def _aggregate_core_features(self, df_technical: pd.DataFrame) -> pd.DataFrame:
        """Agrega apenas features principais"""
        if df_technical.empty:
            return pd.DataFrame()

        # Features principais baseadas em análise de importância
        core_indicators = [
            'returns', 'volatility_20', 'rsi_14', 'macd', 'volume_ratio',
            'atr', 'bb_width', 'momentum_10', 'adx', 'obv_ratio'
        ]

        available_indicators = [col for col in core_indicators if col in df_technical.columns]

        if len(available_indicators) < 3:
            # Fallback para features numéricas básicas
            available_indicators = [col for col in df_technical.columns
                                  if col not in ['Date', 'Ticker']
                                  and df_technical[col].dtype in ['float64', 'int64']]
            available_indicators = available_indicators[:8]  # Limitar a 8 features

        try:
            # Apenas média e desvio padrão para reduzir dimensionalidade
            aggregated = df_technical.groupby('Ticker')[available_indicators].agg(['mean', 'std']).reset_index()

            # Renomear colunas
            new_columns = []
            for col in aggregated.columns:
                if col[1]:
                    new_columns.append(f"{col[0]}_{col[1]}")
                else:
                    new_columns.append(col[0])
            aggregated.columns = new_columns

            return aggregated

        except Exception as e:
            print(f"❌ Erro na agregação de features: {str(e)}")
            return pd.DataFrame()

    def _remove_outliers_moderate(self, features: pd.DataFrame) -> pd.DataFrame:
        """Remoção moderada de outliers"""
        numeric_data = features.select_dtypes(include=[np.number])

        if len(numeric_data) < 5:
            return features

        iso_forest = IsolationForest(
            contamination=0.05,  # MENOS AGRESSIVO
            random_state=42,
            n_estimators=100
        )

        outlier_labels = iso_forest.fit_predict(numeric_data.fillna(0))
        clean_mask = outlier_labels == 1

        print(f"🗑️  Removidos {sum(~clean_mask)} outliers moderados")
        return features[clean_mask].reset_index(drop=True)

    def _apply_robust_feature_selection(self, features: pd.DataFrame) -> pd.DataFrame:
        """Seleção robusta de features"""
        if features.empty:
            return features

        numeric_data = features.select_dtypes(include=[np.number])

        if len(numeric_data) < 3:
            return features

        # 1. Remover features com baixa variância
        variances = numeric_data.var()
        high_variance_features = variances[variances > variances.quantile(0.4)].index
        numeric_data = numeric_data[high_variance_features]

        # 2. Selecionar features mais importantes
        if len(numeric_data) > 5:
            # Usar KMeans para criar labels temporárias
            kmeans = KMeans(n_clusters=min(3, len(numeric_data)), random_state=42)
            pseudo_labels = kmeans.fit_predict(numeric_data.fillna(0))

            # Selecionar features com maior poder discriminativo
            f_scores, _ = f_classif(numeric_data.fillna(0), pseudo_labels)
            significant_features = numeric_data.columns[f_scores > np.percentile(f_scores, 40)]

            print(f"🎯 Feature selection: {len(significant_features)} features selecionadas")
            return features[['Ticker'] + list(significant_features)]
        else:
            return features

    def _apply_conservative_dimensionality_reduction(self, features: pd.DataFrame) -> pd.DataFrame:
        """Redução dimensional conservadora"""
        numeric_data = features.select_dtypes(include=[np.number])

        if numeric_data.empty:
            return features

        # Escalonamento robusto
        scaled_data = self.scaler.fit_transform(numeric_data)

        # PCA conservador - manter 70-80% da variância
        if scaled_data.shape[1] > 3:
            pca = PCA(n_components=min(0.75, 1.0 - 2.0/scaled_data.shape[1]))
            scaled_data = pca.fit_transform(scaled_data)
            print(f"📊 PCA conservador: {scaled_data.shape[1]} componentes ({pca.explained_variance_ratio_.sum():.1%} variância)")

        processed_features = pd.DataFrame(scaled_data)
        processed_features['Ticker'] = features['Ticker'].values

        return processed_features

    def _create_minimal_features(self, df_technical: pd.DataFrame) -> pd.DataFrame:
        """Cria features mínimas de fallback"""
        tickers = df_technical['Ticker'].unique()
        return pd.DataFrame({
            'Ticker': tickers,
            'returns_mean': [0.001] * len(tickers),
            'volatility_20_mean': [0.02] * len(tickers),
            'volume_ratio_mean': [1.0] * len(tickers)
        })

    def perform_hybrid_clustering(self, features: pd.DataFrame) -> pd.DataFrame:
        """Executa múltiplos algoritmos e seleciona o melhor"""
        print("🔄 EXECUTANDO CLUSTERIZAÇÃO HÍBRIDA...")

        if len(features) < 4:
            print("❌ Dados insuficientes para clusterização")
            return self._create_simple_clusters(features)

        features_data = features.drop('Ticker', axis=1)

        # Testar múltiplos algoritmos
        results = []

        # 1. Gaussian Mixture Model
        gmm_result = self._test_gmm(features_data)
        if gmm_result:
            results.append(gmm_result)

        # 2. KMeans
        kmeans_result = self._test_kmeans(features_data)
        if kmeans_result:
            results.append(kmeans_result)

        # 3. Spectral Clustering
        spectral_result = self._test_spectral(features_data)
        if spectral_result:
            results.append(spectral_result)

        # 4. DBSCAN (se encontrar clusters)
        dbscan_result = self._test_dbscan(features_data)
        if dbscan_result and dbscan_result['silhouette'] > 0:  # DBSCAN pode retornar -1
            results.append(dbscan_result)

        # Selecionar o melhor método
        if results:
            best_result = max(results, key=lambda x: x['silhouette'])
            self.best_method = best_result['method']
            self.best_score = best_result['silhouette']
            self.best_labels = best_result['labels']

            print(f"🎯 MELHOR MÉTODO: {self.best_method} (Silhouette: {self.best_score:.4f})")

            result_df = pd.DataFrame({
                'Ticker': features['Ticker'],
                'Cluster': self.best_labels,
                'Method': self.best_method,
                'Silhouette_Score': self.best_score
            })

            self._show_hybrid_results(result_df)
            return result_df
        else:
            print("❌ Nenhum método produziu clusters válidos")
            return self._create_simple_clusters(features)

    def _test_gmm(self, features_data: pd.DataFrame) -> Dict:
        """Testa Gaussian Mixture Model"""
        try:
            best_silhouette = -1
            best_labels = None

            for n_comp in range(self.config.min_clusters, self.config.max_clusters + 1):
                if n_comp >= len(features_data):
                    break

                gmm = GaussianMixture(
                    n_components=n_comp,
                    covariance_type='tied',  # MAIS ESTÁVEL
                    random_state=42,
                    n_init=20
                )
                labels = gmm.fit_predict(features_data)

                if len(np.unique(labels)) > 1:
                    silhouette = silhouette_score(features_data, labels)

                    if silhouette > best_silhouette:
                        best_silhouette = silhouette
                        best_labels = labels

            if best_labels is not None:
                return {
                    'method': f'GMM_{len(np.unique(best_labels))}',
                    'labels': best_labels,
                    'silhouette': best_silhouette
                }

        except Exception as e:
            print(f"⚠️  GMM falhou: {str(e)}")

        return None

    def _test_kmeans(self, features_data: pd.DataFrame) -> Dict:
        """Testa KMeans"""
        try:
            best_silhouette = -1
            best_labels = None

            for n_comp in range(self.config.min_clusters, self.config.max_clusters + 1):
                if n_comp >= len(features_data):
                    break

                kmeans = KMeans(
                    n_clusters=n_comp,
                    random_state=42,
                    n_init=20
                )
                labels = kmeans.fit_predict(features_data)

                if len(np.unique(labels)) > 1:
                    silhouette = silhouette_score(features_data, labels)

                    if silhouette > best_silhouette:
                        best_silhouette = silhouette
                        best_labels = labels

            if best_labels is not None:
                return {
                    'method': f'KMeans_{len(np.unique(best_labels))}',
                    'labels': best_labels,
                    'silhouette': best_silhouette
                }

        except Exception as e:
            print(f"⚠️  KMeans falhou: {str(e)}")

        return None

    def _test_spectral(self, features_data: pd.DataFrame) -> Dict:
        """Testa Spectral Clustering"""
        try:
            spectral = SpectralClustering(
                n_clusters=self.alt_config.spectral_n_clusters,
                affinity=self.alt_config.spectral_affinity,
                random_state=42
            )
            labels = spectral.fit_predict(features_data)

            if len(np.unique(labels)) > 1:
                silhouette = silhouette_score(features_data, labels)

                return {
                    'method': f'Spectral_{len(np.unique(labels))}',
                    'labels': labels,
                    'silhouette': silhouette
                }

        except Exception as e:
            print(f"⚠️  Spectral Clustering falhou: {str(e)}")

        return None

    def _test_dbscan(self, features_data: pd.DataFrame) -> Dict:
        """Testa DBSCAN"""
        try:
            dbscan = DBSCAN(
                eps=self.alt_config.dbscan_eps,
                min_samples=self.alt_config.dbscan_min_samples,
                metric=self.alt_config.dbscan_metric
            )
            labels = dbscan.fit_predict(features_data)

            # DBSCAN pode retornar apenas 1 cluster (-1 são outliers)
            unique_labels = set(labels)
            if len(unique_labels) > 1 and -1 in unique_labels:
                unique_labels.remove(-1)

            if len(unique_labels) > 1:
                # Calcular silhouette apenas para pontos não outliers
                non_outlier_mask = labels != -1
                if non_outlier_mask.sum() > 1:
                    silhouette = silhouette_score(features_data[non_outlier_mask],
                                                labels[non_outlier_mask])

                    return {
                        'method': f'DBSCAN_{len(unique_labels)}',
                        'labels': labels,
                        'silhouette': silhouette
                    }

        except Exception as e:
            print(f"⚠️  DBSCAN falhou: {str(e)}")

        return None

    def _create_simple_clusters(self, features: pd.DataFrame) -> pd.DataFrame:
        """Cria clusters simples como fallback"""
        tickers = features['Ticker']
        n_clusters = min(3, len(tickers))

        # Clusterização simples baseada em volatilidade e returns
        if 'returns_mean' in features.columns and 'volatility_20_mean' in features.columns:
            # Usar KMeans simples
            feature_data = features[['returns_mean', 'volatility_20_mean']].fillna(0)
            kmeans = KMeans(n_clusters=n_clusters, random_state=42)
            clusters = kmeans.fit_predict(feature_data)
        else:
            clusters = [i % n_clusters for i in range(len(tickers))]

        return pd.DataFrame({
            'Ticker': tickers,
            'Cluster': clusters,
            'Method': 'Fallback_KMeans',
            'Silhouette_Score': 0.0
        })

    def _show_hybrid_results(self, cluster_df: pd.DataFrame):
        """Mostra resultados da clusterização híbrida"""
        if cluster_df.empty:
            return

        cluster_counts = cluster_df['Cluster'].value_counts().sort_index()
        method = cluster_df['Method'].iloc[0]
        silhouette = cluster_df['Silhouette_Score'].iloc[0]

        print(f"\n📊 RESULTADOS CLUSTERIZAÇÃO HÍBRIDA:")
        print(f"   • Método selecionado: {method}")
        print(f"   • Silhouette Score: {silhouette:.4f}")
        print(f"   • Número de clusters: {len(cluster_counts)}")

        for cluster_id, count in cluster_counts.items():
            cluster_data = cluster_df[cluster_df['Cluster'] == cluster_id]
            tickers_in_cluster = cluster_data['Ticker'].tolist()

            print(f"   ✅ Cluster {cluster_id}: {count:2d} ativos")
            if tickers_in_cluster and len(tickers_in_cluster) <= 5:
                print(f"      {', '.join(tickers_in_cluster)}")

