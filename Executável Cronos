class OptimizedTechnicalFeatureEngineer:
    """Engineer de features focado nas mais discriminativas - VERSÃO CORRIGIDA"""

    def __init__(self, config: TechnicalConfig = None):
        self.config = config or TechnicalConfig()
        self.essential_features = [
            'returns', 'volatility_20', 'rsi_14', 'macd', 'volume_ratio',
            'atr', 'bb_width', 'momentum_10', 'adx', 'obv'
        ]

    def calculate_core_indicators(self, df: pd.DataFrame) -> pd.DataFrame:
        """Calcula apenas indicadores essenciais - VERSÃO CORRIGIDA"""
        try:
            df = df.copy()

            if len(df) < 100:
                return None

            df = df.sort_values('Date').reset_index(drop=True)

            # Garantir que as colunas são numéricas
            df['High'] = pd.to_numeric(df['High'], errors='coerce')
            df['Low'] = pd.to_numeric(df['Low'], errors='coerce')
            df['Close'] = pd.to_numeric(df['Close'], errors='coerce')
            df['Volume'] = pd.to_numeric(df['Volume'], errors='coerce')

            high = df['High'].values
            low = df['Low'].values
            close = df['Close'].values
            volume = df['Volume'].values

            print(f"📊 Calculando indicadores essenciais para {df['Ticker'].iloc[0]}...")

            # 1. RETURNS E VOLATILIDADE BÁSICA
            df = self._calculate_basic_metrics(df, close, volume)

            # 2. INDICADORES DE TENDÊNCIA (apenas essenciais)
            df = self._calculate_trend_indicators(df, close, high, low)

            # 3. INDICADORES DE MOMENTUM (apenas essenciais)
            df = self._calculate_momentum_indicators(df, close, high, low, volume)

            # 4. INDICADORES DE VOLATILIDADE (apenas essenciais)
            df = self._calculate_volatility_indicators(df, close, high, low)

            # 5. INDICADORES DE VOLUME (apenas essenciais)
            df = self._calculate_volume_indicators(df, close, volume)

            # Preencher valores NaN
            df = df.fillna(method='bfill').fillna(method='ffill').fillna(0)

            # Manter apenas features essenciais
            available_features = [f for f in self.essential_features if f in df.columns]
            keep_columns = ['Date', 'Ticker'] + available_features
            df = df[keep_columns]

            print(f"✅ {df['Ticker'].iloc[0]}: {len(available_features)} indicadores essenciais")

            return df

        except Exception as e:
            print(f"❌ Erro no cálculo de indicadores para {df['Ticker'].iloc[0] if 'Ticker' in df.columns else 'unknown'}: {str(e)}")
            import traceback
            traceback.print_exc()
            return None

    def _calculate_basic_metrics(self, df: pd.DataFrame, close: np.ndarray, volume: np.ndarray) -> pd.DataFrame:
        """Métricas básicas essenciais - VERSÃO CORRIGIDA"""
        # Returns - CORREÇÃO: usar numpy arrays diretamente
        returns = np.zeros(len(close))
        returns[1:] = np.diff(close) / close[:-1]

        df['returns'] = returns

        # Returns 5 dias
        returns_5d = np.zeros(len(close))
        for i in range(5, len(close)):
            if close[i-5] != 0:
                returns_5d[i] = (close[i] - close[i-5]) / close[i-5]
        df['returns_5d'] = returns_5d

        # Returns 21 dias
        returns_21d = np.zeros(len(close))
        for i in range(21, len(close)):
            if close[i-21] != 0:
                returns_21d[i] = (close[i] - close[i-21]) / close[i-21]
        df['returns_21d'] = returns_21d

        # Volatilidade - CORREÇÃO: cálculo manual com numpy
        volatility_10 = np.zeros(len(close))
        volatility_20 = np.zeros(len(close))

        for i in range(10, len(close)):
            if i >= 10:
                volatility_10[i] = np.std(returns[max(0, i-9):i+1])

        for i in range(20, len(close)):
            if i >= 20:
                volatility_20[i] = np.std(returns[max(0, i-19):i+1])

        df['volatility_10'] = volatility_10
        df['volatility_20'] = volatility_20

        # Volume básico - CORREÇÃO: cálculo manual
        volume_sma_20 = np.zeros(len(volume))
        for i in range(20, len(volume)):
            volume_sma_20[i] = np.mean(volume[i-19:i+1])
        df['volume_sma_20'] = volume_sma_20

        volume_ratio = np.ones(len(volume))
        for i in range(20, len(volume)):
            if volume_sma_20[i] != 0:
                volume_ratio[i] = volume[i] / volume_sma_20[i]
        df['volume_ratio'] = volume_ratio

        return df

    def _calculate_trend_indicators(self, df: pd.DataFrame, close: np.ndarray,
                                  high: np.ndarray, low: np.ndarray) -> pd.DataFrame:
        """Indicadores de tendência essenciais - VERSÃO CORRIGIDA"""
        try:
            # Médias móveis simples - CORREÇÃO: cálculo manual
            for period in [10, 20, 50]:
                sma_values = np.zeros(len(close))
                for i in range(period-1, len(close)):
                    sma_values[i] = np.mean(close[i-period+1:i+1])
                df[f'sma_{period}'] = sma_values

            # MACD - CORREÇÃO: usar talib diretamente com arrays numpy
            try:
                macd, macd_signal, macd_hist = talib.MACD(close,
                                                         fastperiod=self.config.macd_fast,
                                                         slowperiod=self.config.macd_slow,
                                                         signalperiod=self.config.macd_signal)
                df['macd'] = macd
            except Exception as e:
                print(f"⚠️  Erro no MACD: {e}")
                df['macd'] = 0

            # ADX
            try:
                adx = talib.ADX(high, low, close, timeperiod=self.config.adx_period)
                df['adx'] = adx
            except Exception as e:
                print(f"⚠️  Erro no ADX: {e}")
                df['adx'] = 50

        except Exception as e:
            print(f"❌ Erro em indicadores de tendência: {str(e)}")

        return df

    def _calculate_momentum_indicators(self, df: pd.DataFrame, close: np.ndarray,
                                     high: np.ndarray, low: np.ndarray, volume: np.ndarray) -> pd.DataFrame:
        """Indicadores de momentum essenciais - VERSÃO CORRIGIDA"""
        # RSI
        try:
            rsi = talib.RSI(close, timeperiod=14)
            df['rsi_14'] = rsi
        except Exception as e:
            print(f"⚠️  Erro no RSI: {e}")
            df['rsi_14'] = 50

        # Momentum - CORREÇÃO: cálculo manual
        momentum_10 = np.zeros(len(close))
        for i in range(10, len(close)):
            if close[i-10] != 0:
                momentum_10[i] = close[i] / close[i-10] - 1
        df['momentum_10'] = momentum_10

        return df

    def _calculate_volatility_indicators(self, df: pd.DataFrame, close: np.ndarray,
                                       high: np.ndarray, low: np.ndarray) -> pd.DataFrame:
        """Indicadores de volatilidade essenciais - VERSÃO CORRIGIDA"""
        # ATR
        try:
            atr = talib.ATR(high, low, close, timeperiod=self.config.atr_period)
            df['atr'] = atr
        except Exception as e:
            print(f"⚠️  Erro no ATR: {e}")
            df['atr'] = 0

        # Bandas de Bollinger
        try:
            bb_upper, bb_middle, bb_lower = talib.BBANDS(close,
                                                        timeperiod=self.config.bb_period,
                                                        nbdevup=2, nbdevdn=2, matype=0)
            bb_width = np.zeros(len(close))
            for i in range(len(close)):
                if bb_middle[i] != 0:
                    bb_width[i] = (bb_upper[i] - bb_lower[i]) / bb_middle[i]
            df['bb_width'] = bb_width
        except Exception as e:
            print(f"⚠️  Erro nas Bandas de Bollinger: {e}")
            df['bb_width'] = 0

        return df

    def _calculate_volume_indicators(self, df: pd.DataFrame, close: np.ndarray,
                                   volume: np.ndarray) -> pd.DataFrame:
        """Indicadores de volume essenciais - VERSÃO CORRIGIDA"""
        # OBV - CORREÇÃO: cálculo manual
        try:
            obv = np.zeros(len(volume))
            obv[0] = volume[0]

            for i in range(1, len(volume)):
                if close[i] > close[i-1]:
                    obv[i] = obv[i-1] + volume[i]
                elif close[i] < close[i-1]:
                    obv[i] = obv[i-1] - volume[i]
                else:
                    obv[i] = obv[i-1]

            df['obv'] = obv

            # OBV SMA
            obv_sma = np.zeros(len(obv))
            for i in range(self.config.obv_period-1, len(obv)):
                obv_sma[i] = np.mean(obv[i-self.config.obv_period+1:i+1])
            df['obv_sma'] = obv_sma

            obv_ratio = np.ones(len(obv))
            for i in range(self.config.obv_period-1, len(obv)):
                if obv_sma[i] != 0:
                    obv_ratio[i] = obv[i] / obv_sma[i]
            df['obv_ratio'] = obv_ratio

        except Exception as e:
            print(f"⚠️  Erro no OBV: {e}")
            df['obv'] = 0
            df['obv_ratio'] = 1

        return df

