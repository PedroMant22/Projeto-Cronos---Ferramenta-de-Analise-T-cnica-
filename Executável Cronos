            print(f"❌ CARTEIRA NEURAL FICOU ATRÁS DO IBOVESPA EM {underperformance:.2%}")

    def run_backtest(self):
        """
        Executa o backtesting completo
        """
        print("🚀 INICIANDO BACKTESTING 2024...")

        # Carregar carteira
        if not self.load_portfolio():
            return

        # Executar todos os passos
        if not self.fetch_data():
            return

        self.calcular_retornos()
        self.calcular_todas_metricas()

        # Gerar relatório
        self.gerar_relatorio()

        # Plotar gráficos
        print("\n📊 Gerando gráficos...")
        self.plot_desempenho()
        self.plot_drawdown()
        self.plot_retornos_mensais()

        print("\n✅ Backtesting 2024 concluído com sucesso!")

