class NeuralNetworkPortfolio:
    """Sistema de rede neural para construção de carteira - VERSÃO CORRIGIDA"""

    def __init__(self):
        self.model = None
        self.scaler = StandardScaler()
        self.history = None

    def load_cluster_data(self):
        """Carrega dados da clusterização"""
        try:
            with open('clusterizacao_resultados.json', 'r') as f:
                return json.load(f)
        except Exception as e:
            print(f"❌ Erro ao carregar dados de clusterização: {e}")
            return None

    def prepare_training_data(self, cluster_data):
        """Prepara dados para treinamento - VERSÃO CORRIGIDA"""
        print("📊 Preparando dados para rede neural...")

        # Carregar dados de preços dos arquivos salvos
        try:
            df_technical = pd.read_csv('resultados_otimizados/dados_tecnicos_otimizados.csv')
            # CORREÇÃO: Converter coluna Date para datetime e garantir que seja timezone-naive
            df_technical['Date'] = pd.to_datetime(df_technical['Date'])
            # Remover timezone se existir
            if df_technical['Date'].dt.tz is not None:
                df_technical['Date'] = df_technical['Date'].dt.tz_localize(None)

            print(f"✅ Dados técnicos carregados: {len(df_technical)} registros")
        except Exception as e:
            print(f"❌ Erro ao carregar dados técnicos: {e}")
            return None, None, None, None

        # Usar apenas os tickers que foram clusterizados
        tickers = cluster_data['tickers']
        df_technical = df_technical[df_technical['Ticker'].isin(tickers)]

        # CORREÇÃO: Usar objetos Timestamp timezone-naive para comparação
        train_start = pd.Timestamp('2017-01-01')
        train_end = pd.Timestamp('2021-12-31')
        test_start = pd.Timestamp('2022-01-01')
        test_end = pd.Timestamp('2023-12-31')

        # Separar treino (até 2021) e teste (2022-2023)
        train_data = df_technical[(df_technical['Date'] >= train_start) &
                                 (df_technical['Date'] <= train_end)].copy()
        test_data = df_technical[(df_technical['Date'] >= test_start) &
                                (df_technical['Date'] <= test_end)].copy()

        print(f"📊 Dados de treino: {len(train_data)} registros")
        print(f"📊 Dados de teste: {len(test_data)} registros")

        if len(train_data) == 0 or len(test_data) == 0:
            print("❌ Dados insuficientes após separação temporal")
            return None, None, None, None

        # Criar features robustas
        X_train, y_train = self.create_improved_features(train_data)
        X_test, y_test = self.create_improved_features(test_data)

        if X_train is None or X_train.empty or len(y_train) == 0:
            print("❌ Não foi possível criar features de treino")
            return None, None, None, None

        print(f"✅ Features criadas: {X_train.shape[1]} features")
        print(f"📊 Amostras treino: {X_train.shape[0]}, teste: {X_test.shape[0] if X_test is not None else 0}")

        return X_train, X_test, y_train, y_test

    def create_improved_features(self, data):
        """Cria features melhoradas usando dados técnicos já processados"""
        if data.empty:
            return pd.DataFrame(), []

        # Selecionar colunas de features (excluir Date e Ticker)
        feature_columns = [col for col in data.columns if col not in ['Date', 'Ticker']]

        if len(feature_columns) == 0:
            print("❌ Nenhuma feature disponível")
            return pd.DataFrame(), []

        # Agrupar por ticker e pegar as últimas observações de cada mês para reduzir dimensionalidade
        data['YearMonth'] = data['Date'].dt.to_period('M')
        latest_data = data.sort_values('Date').groupby(['Ticker', 'YearMonth']).last().reset_index()

        # Preparar features
        X = latest_data[feature_columns].copy()

        # Preencher valores NaN
        X = X.fillna(method='ffill').fillna(method='bfill').fillna(0)

        # Remover colunas com variância zero
        X = X.loc[:, X.std() > 0]

        if X.empty:
            print("❌ Todas as features têm variância zero após pré-processamento")
            return pd.DataFrame(), []

        # Calcular retorno futuro (target) - simplificado
        # Para cada ativo, calcular o retorno médio no próximo período
        y = self.calculate_simple_future_returns(latest_data)

        print(f"✅ Features melhoradas criadas: {X.shape[1]} features, {X.shape[0]} amostras")
        return X, y

    def calculate_simple_future_returns(self, data):
        """Calcula retornos futuros de forma simplificada"""
        returns = []

        for ticker in data['Ticker'].unique():
            ticker_data = data[data['Ticker'] == ticker].sort_values('Date')

            if len(ticker_data) < 2:
                returns.extend([0] * len(ticker_data))
                continue

            # Calcular retorno médio baseado na volatilidade histórica
            if 'volatility_20' in ticker_data.columns:
                vol_mean = ticker_data['volatility_20'].mean()
                # Retorno esperado proporcional à volatilidade (simulação)
                expected_return = np.random.normal(0, abs(vol_mean) * 0.1, len(ticker_data))
            else:
                expected_return = np.random.normal(0, 0.02, len(ticker_data))

            returns.extend(expected_return)

        returns = np.array(returns)
        # Limitar retornos extremos
        returns = np.clip(returns, -0.3, 0.3)

        return returns

    def build_improved_model(self, input_dim):
        """Constrói modelo neural melhorado"""
        try:
            import tensorflow as tf
            from tensorflow.keras.models import Sequential
            from tensorflow.keras.layers import Dense, Dropout, BatchNormalization
            from tensorflow.keras.optimizers import Adam
            from tensorflow.keras.regularizers import l2

            model = Sequential([
                Dense(64, activation='relu', input_shape=(input_dim,), kernel_regularizer=l2(0.001)),
                BatchNormalization(),
                Dropout(0.3),

                Dense(32, activation='relu', kernel_regularizer=l2(0.001)),
                BatchNormalization(),
                Dropout(0.2),

                Dense(16, activation='relu'),
                Dropout(0.1),

                Dense(1, activation='linear')
            ])

            model.compile(
                optimizer=Adam(learning_rate=0.001),
                loss='mse',
                metrics=['mae']
            )

            return model
        except ImportError:
            print("❌ TensorFlow não está instalado. Usando fallback...")
            return self.build_fallback_model(input_dim)

    def build_fallback_model(self, input_dim):
        """Modelo fallback sem TensorFlow"""
        from sklearn.ensemble import RandomForestRegressor
        return RandomForestRegressor(n_estimators=100, random_state=42)

    def train_model(self):
        """Treina o modelo de rede neural - VERSÃO CORRIGIDA"""
        print("🧠 Treinando rede neural...")

        # Carregar dados da clusterização
        cluster_data = self.load_cluster_data()
        if not cluster_data:
            print("❌ Não foi possível carregar dados da clusterização")
            return None

        # Preparar dados
        X_train, X_test, y_train, y_test = self.prepare_training_data(cluster_data)

        if X_train is None or len(X_train) == 0:
            print("❌ Dados insuficientes para treinamento")
            return None

        print(f"📊 Dados de treino: {X_train.shape[0]} amostras, {X_train.shape[1]} features")

        # Se não há dados de teste suficientes, fazer split
        if X_test is None or len(X_test) == 0 or len(y_test) == 0:
            print("⚠️  Sem dados de teste suficientes, usando split do treino")
            from sklearn.model_selection import train_test_split
            X_train, X_test, y_train, y_test = train_test_split(
                X_train, y_train, test_size=0.2, random_state=42
            )

        print(f"📊 Dados de teste: {X_test.shape[0]} amostras")

        # Verificar se estamos usando TensorFlow ou fallback
        try:
            from tensorflow.keras.models import Sequential
            using_tensorflow = True
        except ImportError:
            using_tensorflow = False

        if using_tensorflow:
            # Normalizar para TensorFlow
            X_train_scaled = self.scaler.fit_transform(X_train)
            X_test_scaled = self.scaler.transform(X_test)

            # Construir e treinar modelo
            self.model = self.build_improved_model(X_train_scaled.shape[1])

            print("📈 Iniciando treinamento TensorFlow...")

            # Callback para early stopping
            from tensorflow.keras.callbacks import EarlyStopping
            early_stop = EarlyStopping(monitor='val_loss', patience=10, restore_best_weights=True)

            self.history = self.model.fit(
                X_train_scaled, y_train,
                validation_data=(X_test_scaled, y_test),
                epochs=50,
                batch_size=32,
                verbose=1,
                callbacks=[early_stop]
            )

            # Avaliar modelo
            train_loss = self.model.evaluate(X_train_scaled, y_train, verbose=0)
            test_loss = self.model.evaluate(X_test_scaled, y_test, verbose=0)

            print(f"✅ Treinamento TensorFlow concluído")
            print(f"   Loss: {train_loss[0]:.6f} (treino), {test_loss[0]:.6f} (teste)")

        else:
            # Usar RandomForest como fallback
            print("🔧 Usando RandomForest como fallback...")
            self.model = self.build_fallback_model(X_train.shape[1])
            self.model.fit(X_train, y_train)

            # Avaliar
            train_score = self.model.score(X_train, y_train)
            test_score = self.model.score(X_test, y_test)

            print(f"✅ Treinamento RandomForest concluído")
            print(f"   R² Score: {train_score:.4f} (treino), {test_score:.4f} (teste)")

        return self.model

    def generate_portfolio_2024(self):
        """Gera carteira para 2024 baseada no modelo"""
        print("💰 Gerando carteira para 2024...")

        if self.model is None:
            print("❌ Modelo não treinado")
            return None

        # Carregar dados da clusterização
        cluster_data = self.load_cluster_data()
        if not cluster_data:
            return None

        # Usar dados técnicos mais recentes (últimos disponíveis)
        try:
            df_technical = pd.read_csv('resultados_otimizados/dados_tecnicos_otimizados.csv')
            # CORREÇÃO: Converter coluna Date para datetime e garantir timezone-naive
            df_technical['Date'] = pd.to_datetime(df_technical['Date'])
            if df_technical['Date'].dt.tz is not None:
                df_technical['Date'] = df_technical['Date'].dt.tz_localize(None)

            # Pegar dados mais recentes de cada ticker
            latest_data = df_technical.sort_values('Date').groupby('Ticker').last().reset_index()
            latest_data = latest_data[latest_data['Ticker'].isin(cluster_data['tickers'])]

        except Exception as e:
            print(f"❌ Erro ao carregar dados técnicos: {e}")
            return None

        if latest_data.empty:
            print("❌ Nenhum dado recente disponível")
            return None

        # Preparar features
        feature_columns = [col for col in latest_data.columns if col not in ['Date', 'Ticker', 'YearMonth']]
        X_current = latest_data[feature_columns].fillna(0)

        # Remover colunas com variância zero
        X_current = X_current.loc[:, X_current.std() > 0]

        if X_current.empty:
            print("❌ Nenhuma feature válida para previsão")
            return None

        # Fazer previsões
        try:
            from tensorflow.keras.models import Sequential
            using_tensorflow = True
        except ImportError:
            using_tensorflow = False

        if using_tensorflow:
            X_scaled = self.scaler.transform(X_current)
            predictions = self.model.predict(X_scaled, verbose=0).flatten()
        else:
            predictions = self.model.predict(X_current)

        # Criar carteira baseada nas previsões
        portfolio = {}
        if len(predictions) > 0:
            # Normalizar previsões para pesos (usar softmax)
            exp_preds = np.exp(predictions - np.max(predictions))
            weights = exp_preds / np.sum(exp_preds)

            for i, ticker in enumerate(latest_data['Ticker']):
                if i < len(weights):
                    portfolio[ticker] = float(weights[i])

        # Garantir que temos pelo menos alguns ativos
        if not portfolio:
            # Fallback: distribuição igualitária
            for ticker in cluster_data['tickers'][:10]:  # Limitar a 10 ativos
                portfolio[ticker] = 0.1

        # Normalizar pesos para soma = 1
        total_weight = sum(portfolio.values())
        if total_weight > 0:
            portfolio = {k: v/total_weight for k, v in portfolio.items()}

        # Salvar carteira
        portfolio_data = {
            'portfolio': portfolio,
            'generation_date': datetime.now().isoformat(),
            'tickers_included': list(portfolio.keys()),
            'total_assets': len(portfolio)
        }

        with open('carteira_2024.json', 'w') as f:
            json.dump(portfolio_data, f, indent=2)

        print(f"✅ Carteira para 2024 gerada com {len(portfolio)} ativos")

        # Mostrar top ativos
        sorted_portfolio = sorted(portfolio.items(), key=lambda x: x[1], reverse=True)[:5]
        print("🏆 Top 5 ativos na carteira:")
        for ticker, weight in sorted_portfolio:
            print(f"   {ticker}: {weight:.1%}")

        return portfolio

