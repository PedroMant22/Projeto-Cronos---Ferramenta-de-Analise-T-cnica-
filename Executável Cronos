        ax.fill_between(drawdown_carteira.index, drawdown_carteira.values, 0,
                       alpha=0.7, label='Carteira Neural', color=self.colors[0])
        ax.fill_between(drawdown_benchmark.index, drawdown_benchmark.values, 0,
