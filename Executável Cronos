    def _download_data(self) -> pd.DataFrame:
        """Baixa dados históricos"""
        print("📥 Baixando dados do Yahoo Finance...")
        all_data = []

        for ticker in TICKERS:
            try:
                stock = yf.Ticker(ticker)
                df = stock.history(start='2017-01-01', end='2023-12-31')

                if df.empty:
                    continue

                df = df.reset_index()

                # CORREÇÃO: Remover timezone das datas se existir
                if hasattr(df['Date'], 'dt'):
                    if df['Date'].dt.tz is not None:
                        df['Date'] = df['Date'].dt.tz_localize(None)

                df['Ticker'] = ticker.replace('.SA', '')

                required_cols = ['Date', 'Open', 'High', 'Low', 'Close', 'Volume']
                for col in required_cols:
                    if col not in df.columns:
                        if col == 'Volume':
                            df['Volume'] = 0
                        else:
                            continue

                all_data.append(df[required_cols + ['Ticker']])
                print(f"✅ {ticker}: {len(df)} registros")

            except Exception as e:
                print(f"❌ {ticker}: {str(e)}")
                continue

        if not all_data:
            return None

        df_combined = pd.concat(all_data, ignore_index=True)
        df_combined = df_combined.sort_values(['Ticker', 'Date']).reset_index(drop=True)

        print(f"📊 Total: {len(df_combined)} registros de {len(all_data)} tickers")
        return df_combined

    def _calculate_optimized_indicators(self, df_historical: pd.DataFrame) -> pd.DataFrame:
        """Calcula indicadores otimizados"""
        technical_data = []

        for ticker in df_historical['Ticker'].unique():
            ticker_data = df_historical[df_historical['Ticker'] == ticker].copy()

            if len(ticker_data) < 100:
                continue

            ticker_technical = self.technical_engineer.calculate_core_indicators(ticker_data)

            if ticker_technical is not None:
                technical_data.append(ticker_technical)
            else:
                print(f"⚠️  {ticker}: falha nos indicadores essenciais")

        if not technical_data:
            return None

        result = pd.concat(technical_data, ignore_index=True)
        print(f"📈 Features essenciais calculadas: {len([col for col in result.columns if col not in ['Date', 'Ticker']])}")
        return result

    def _analyze_clustering_quality(self, features: pd.DataFrame, cluster_df: pd.DataFrame):
        """Analisa qualidade da clusterização"""
        if cluster_df.empty:
            return

        features_data = features.drop('Ticker', axis=1)
        silhouette = cluster_df['Silhouette_Score'].iloc[0]
        method = cluster_df['Method'].iloc[0]

        # Calcular métricas adicionais
        if len(np.unique(cluster_df['Cluster'])) > 1:
            calinski = calinski_harabasz_score(features_data, cluster_df['Cluster'])
            davies = davies_bouldin_score(features_data, cluster_df['Cluster'])
        else:
            calinski = 0
            davies = float('inf')

        print(f"\n📈 ANÁLISE DE QUALIDADE:")
        print(f"   • Método: {method}")
        print(f"   • Silhouette Score: {silhouette:.4f}")
        print(f"   • Calinski-Harabasz: {calinski:.2f}")
        print(f"   • Davies-Bouldin: {davies:.2f}")

        if silhouette >= 0.15:
            print("🎉 CLUSTERING DE QUALIDADE ACEITÁVEL!")
        elif silhouette >= 0.10:
            print("⚠️  Clustering moderado - considerar ajustes")
        else:
            print("🔴 Clustering fraco - revisar abordagem")

    def _save_optimized_results(self, df_technical: pd.DataFrame, cluster_df: pd.DataFrame) -> Dict:
        """Salva resultados otimizados e retorna no formato esperado"""
        os.makedirs('resultados_otimizados', exist_ok=True)

        # Salvar CSVs
        df_technical.to_csv('resultados_otimizados/dados_tecnicos_otimizados.csv', index=False)
        cluster_df.to_csv('resultados_otimizados/clusters_hibridos.csv', index=False)

        # Preparar resultado no formato JSON esperado
        feature_cols = [col for col in df_technical.columns if col not in ['Date', 'Ticker']]

        resultados = {
            'tickers': cluster_df['Ticker'].tolist(),
            'clusters': cluster_df['Cluster'].tolist(),
            'silhouette_score': cluster_df['Silhouette_Score'].iloc[0] if not cluster_df.empty else 0,
            'method': cluster_df['Method'].iloc[0] if not cluster_df.empty else "Unknown",
            'feature_names': feature_cols
        }

        # Salvar JSON
        with open('clusterizacao_resultados.json', 'w') as f:
            json.dump(resultados, f, indent=2)

        print("💾 Resultados salvos em: resultados_otimizados/ e clusterizacao_resultados.json")

        if not cluster_df.empty:
            silhouette = cluster_df['Silhouette_Score'].iloc[0]
            method = cluster_df['Method'].iloc[0]
            n_clusters = cluster_df['Cluster'].nunique()

            print(f"\n📊 RESUMO FINAL:")
            print(f"   • Ativos processados: {len(cluster_df)}")
            print(f"   • Método selecionado: {method}")
            print(f"   • Número de clusters: {n_clusters}")
            print(f"   • Silhouette Score: {silhouette:.4f}")

        return resultados

