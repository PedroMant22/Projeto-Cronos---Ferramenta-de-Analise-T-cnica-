    def load_portfolio(self):
        """Carrega a carteira do arquivo JSON"""
        try:
            with open(self.carteira_file, 'r') as f:
                portfolio_data = json.load(f)
                self.carteira = portfolio_data['portfolio']
                print(f"✅ Carteira carregada: {len(self.carteira)} ativos")
                return True
        except Exception as e:
            print(f"❌ Erro ao carregar carteira: {e}")
            return False

    def fetch_data(self):
        """
        Busca dados históricos dos ativos e do benchmark - VERSÃO CORRIGIDA
        """
        print("📥 Buscando dados para backtesting...")

        try:
            # Buscar dados dos ativos
            tickers = [f"{ticker}.SA" for ticker in self.carteira.keys()]
            dados_completos = yf.download(tickers, start=self.start_date, end=self.end_date, progress=False)

            if dados_completos.empty:
                print("❌ Nenhum dado encontrado para os ativos")
                return False

            # CORREÇÃO: Verificar se 'Adj Close' existe, senão usar 'Close'
            if 'Adj Close' in dados_completos.columns:
                self.dados_ativos = dados_completos['Adj Close']
            else:
                self.dados_ativos = dados_completos['Close']

            # Buscar dados do benchmark - CORREÇÃO: garantir que é Series
            benchmark_data = yf.download(self.benchmark_ticker,
                                       start=self.start_date,
                                       end=self.end_date,
                                       progress=False)

            if benchmark_data.empty:
                print("❌ Nenhum dado encontrado para o benchmark")
                return False

            # CORREÇÃO: Extrair a Series do benchmark
            if 'Adj Close' in benchmark_data.columns:
                self.dados_benchmark = benchmark_data['Adj Close']
            else:
                self.dados_benchmark = benchmark_data['Close']

            # Se ainda for DataFrame, pegar a primeira coluna
            if isinstance(self.dados_benchmark, pd.DataFrame):
                self.dados_benchmark = self.dados_benchmark.iloc[:, 0]

            print(f"✅ Dados baixados com sucesso!")
            if len(self.dados_ativos) > 0:
                print(f"📅 Período: {self.dados_ativos.index[0].strftime('%Y-%m-%d')} a {self.dados_ativos.index[-1].strftime('%Y-%m-%d')}")
            print(f"📊 Ativos: {len(tickers)}")
            print(f"📊 Benchmark: {self.benchmark_ticker} ({len(self.dados_benchmark)} registros)")

        except Exception as e:
            print(f"❌ Erro ao baixar dados: {e}")
            return False
        return True

    def calcular_retornos(self):
        """
        Calcula retornos da carteira e do benchmark - VERSÃO CORRIGIDA
        """
        if self.dados_ativos is None or self.dados_benchmark is None:
            raise ValueError("Dados não encontrados. Execute fetch_data() primeiro.")

        # CORREÇÃO: Garantir que os dados do benchmark são uma Series
        if isinstance(self.dados_benchmark, pd.DataFrame):
            if len(self.dados_benchmark.columns) > 0:
                self.dados_benchmark = self.dados_benchmark.iloc[:, 0]
            else:
                raise ValueError("DataFrame do benchmark está vazio")

        # Retornos diários dos ativos
        retornos_diarios = self.dados_ativos.pct_change().dropna()

        # Retorno da carteira ponderada
        pesos = np.array(list(self.carteira.values()))
        # Garantir que os pesos somem 1
        pesos = pesos / pesos.sum()

        self.retorno_carteira = (retornos_diarios * pesos).sum(axis=1)

        # Valor da carteira ao longo do tempo (base 100)
        self.valor_carteira = (1 + self.retorno_carteira).cumprod() * 100

        # Retorno e valor do benchmark - CORREÇÃO: garantir que é Series
        self.retorno_benchmark = self.dados_benchmark.pct_change().dropna()
        self.valor_benchmark = (1 + self.retorno_benchmark).cumprod() * 100

        print("✅ Retornos calculados com sucesso!")
        print(f"   📊 Carteira: {len(self.retorno_carteira)} dias de retornos")
        print(f"   📊 Benchmark: {len(self.retorno_benchmark)} dias de retornos")

    def calcular_metricas(self, retornos_diarios, valor_series, nome="Carteira"):
        """
        Calcula métricas de desempenho para uma série de retornos - VERSÃO CORRIGIDA
        """
        if len(retornos_diarios) == 0 or len(valor_series) == 0:
            return {
                'Retorno Total': 0,
                'Retorno Anualizado': 0,
                'Volatilidade Anual': 0,
                'Sharpe Ratio': 0,
                'Max Drawdown': 0,
                'Beta': 0,
                'Alpha': 0,
                'Dias': 0
            }

        # Retorno total
        retorno_total = (valor_series.iloc[-1] / valor_series.iloc[0]) - 1

        # Volatilidade anualizada
        volatilidade = retornos_diarios.std() * np.sqrt(252)

        # Sharpe Ratio (assumindo risco livre = 0)
        sharpe = (retornos_diarios.mean() * 252) / volatilidade if volatilidade != 0 else 0

        # Drawdown
        cummax = valor_series.cummax()
        drawdown = (valor_series - cummax) / cummax
        max_drawdown = drawdown.min()

        # Retorno anualizado
        dias_totais = (valor_series.index[-1] - valor_series.index[0]).days
        retorno_anualizado = (1 + retorno_total) ** (365 / dias_totais) - 1 if dias_totais > 0 else 0

        # CORREÇÃO: Calcular Alpha e Beta com alinhamento adequado
        beta = 1.0
        alpha = 0.0

        if nome == "Carteira" and hasattr(self, 'retorno_benchmark') and len(self.retorno_benchmark) > 0:
            try:
                # Garantir que temos dados suficientes
                if len(retornos_diarios) > 1 and len(self.retorno_benchmark) > 1:
                    # Alinhar os índices manualmente
                    common_dates = retornos_diarios.index.intersection(self.retorno_benchmark.index)

                    if len(common_dates) > 1:  # Precisamos de pelo menos 2 pontos para covariância
                        aligned_returns = retornos_diarios.loc[common_dates]
                        aligned_benchmark = self.retorno_benchmark.loc[common_dates]

                        # Verificar se as séries têm o mesmo comprimento
                        if len(aligned_returns) == len(aligned_benchmark) and len(aligned_returns) > 1:
                            # Converter para arrays numpy e garantir que são 1D
                            returns_array = aligned_returns.values.flatten() if aligned_returns.ndim > 1 else aligned_returns.values
                            benchmark_array = aligned_benchmark.values.flatten() if aligned_benchmark.ndim > 1 else aligned_benchmark.values

                            # Calcular covariância e variância
                            covariance = np.cov(returns_array, benchmark_array)[0, 1]
                            variance = np.var(benchmark_array)

                            beta = covariance / variance if variance != 0 else 1.0

                            # Calcular alpha
                            portfolio_return = retorno_anualizado
                            benchmark_return = (self.valor_benchmark.iloc[-1] / self.valor_benchmark.iloc[0] - 1)
                            benchmark_annualized = (1 + benchmark_return) ** (365 / dias_totais) - 1 if dias_totais > 0 else 0

                            alpha = portfolio_return - (beta * benchmark_annualized)

                            print(f"   📊 Cálculo Beta/Alpha: {len(aligned_returns)} dias comuns, Beta={beta:.3f}, Alpha={alpha:.3%}")
                        else:
                            print(f"   ⚠️  Séries não alinhadas: {len(aligned_returns)} vs {len(aligned_benchmark)}")
                    else:
                        print(f"   ⚠️  Poucos dias comuns: {len(common_dates)}")
                else:
                    print(f"   ⚠️  Dados insuficientes: carteira={len(retornos_diarios)}, benchmark={len(self.retorno_benchmark)}")
            except Exception as e:
                print(f"   ⚠️  Erro no cálculo Beta/Alpha: {e}")
                beta = 1.0
                alpha = 0.0

        metrics = {
            'Retorno Total': retorno_total,
            'Retorno Anualizado': retorno_anualizado,
            'Volatilidade Anual': volatilidade,
            'Sharpe Ratio': sharpe,
            'Max Drawdown': max_drawdown,
            'Beta': beta,
            'Alpha': alpha,
            'Dias': len(valor_series)
        }

        return metrics

    def calcular_todas_metricas(self):
        """
        Calcula métricas para carteira e benchmark
        """
        self.metricas_carteira = self.calcular_metricas(
            self.retorno_carteira, self.valor_carteira, "Carteira"
        )

        self.metricas_benchmark = self.calcular_metricas(
            self.retorno_benchmark, self.valor_benchmark, "Benchmark"
        )

        print("✅ Métricas calculadas com sucesso!")

